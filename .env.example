# Model provider
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Buf Schema Registry credentials. Use these to create the ~/.netrc entry expected by
# uv and Docker builds; CI uses secrets with the same names.
BUF_BUILD_USER=
BUF_BUILD_TOKEN=

# Agent server
ECOM_AGENT_GRPC_HOST=0.0.0.0
ECOM_AGENT_GRPC_PORT=50051
ECOM_AGENT_DEFAULT_MODEL=
ECOM_AGENT_RUNTIME_RPC_TIMEOUT_SECONDS=30

# off | metadata | full
ECOM_AGENT_OBSERVABILITY_MODE=off

# Langfuse observability (credentials are required for metadata/full mode).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# Enable verbose Langfuse SDK/exporter diagnostics.
LANGFUSE_DEBUG=false
LANGFUSE_SAMPLE_RATE=0.2
